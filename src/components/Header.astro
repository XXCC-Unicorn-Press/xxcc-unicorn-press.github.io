---
import config from '../data/config.yml';
---
<header class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-xl font-serif font-bold tracking-tight text-gray-900 hover:text-blue-600 transition-colors">
      {config.publisher.name}
    </a>
    <nav>
      <ul class="flex space-x-6 text-sm font-medium">
        <li>
          <a href="/" class="text-gray-600 hover:text-gray-900 transition-colors">Home</a>
        </li>
        <li>
          <a href="/about" class="text-gray-600 hover:text-gray-900 transition-colors">About</a>
        </li>
        <li>
          <a href={config.publisher.githubOrg} target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-gray-900 transition-colors flex items-center gap-1">
            GitHub
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>