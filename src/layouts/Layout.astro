---
import '../styles/global.css';
import 'katex/dist/katex.min.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import config from '../data/config.yml';

const { title } = Astro.props;
const siteTitle = title ? `${title} | ${config.publisher.name}` : config.publisher.name;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>
	</head>
	<body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col antialiased">
		<Header />
		<main class="flex-grow w-full max-w-5xl mx-auto px-6 py-12">
			<slot />
		</main>
		<Footer />
	</body>
</html>