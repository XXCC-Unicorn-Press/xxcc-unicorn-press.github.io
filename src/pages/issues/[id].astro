---
import Layout from '../../layouts/Layout.astro';
import config from '../../data/config.yml';
import { renderMath } from '../../utils/math';

export async function getStaticPaths() {
  return config.issues.map((issue) => {
    return {
      params: { id: issue.id },
      props: { issue },
    };
  });
}

const { issue } = Astro.props;
const baseUrl = `${config.publisher.siteUrl}/${issue.repoName}`;
const repoUrl = `https://github.com/XXCC-Unicorn-Press/${issue.repoName}`;
---

<Layout title={issue.title}>
